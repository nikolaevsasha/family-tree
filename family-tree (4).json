      "deceased": false,
      "maidenName": ""
    },
    {
      "id": 40,
      "name": "Виктор Николаев",
      "dates": "1929",
      "gender": "m",
      "bio": "Уроженец Самары, чей трудовой путь начался еще в годы Великой Отечественной войны со строительства оборонных заводов, эвакуированных в город. В молодости он успешно занимался спортом, выступая за клуб «Крылья Советов». Получив профессиональное образование в сфере строительства горных предприятий, он посвятил карьеру возведению шахт. Ушел из жизни преждевременно из-за болезни сердца.",
      "x": 280.3462604789837,
      "y": 1465.1130515838788,
      "profession": "",
      "birthPlace": "",
      "burialPlace": "",
      "nationality": "",
