      "deceased": false,
      "maidenName": ""
    },
    {
      "id": 33,
      "name": "Марзия",
      "dates": "?",
      "gender": "f",
      "bio": "Представительница сословия оренбургских дворян. Принадлежность к этому привилегированному классу на Южном Урале традиционно подразумевала высокий уровень образования, следование строгому этикету и глубокие традиции служения государству или обществу, сохранявшиеся в семье на протяжении поколений.",
      "x": 2354.224480063831,
      "y": 1029.3138982898615,
      "profession": "",
      "birthPlace": "",
      "burialPlace": "",
